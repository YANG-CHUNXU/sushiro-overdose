# 复制为 .env（已在 .gitignore）。MCP server 启动时读这些环境变量。
# 也可在桌面端设置页"MCP 助手"里填，桌面端拉起 MCP 时注入。

# Turso 新库（只读 token！去 Turso 控制台为 su-shiro-ryujoxys 库建 a:ro 的 token）
SUSHIRO_MCP_TURSO_URL=libsql://su-shiro-ryujoxys.aws-us-west-2.turso.io
SUSHIRO_MCP_TURSO_TOKEN=

# 桌面端本地端口（默认 39871，被占会递增；桌面端拉起 MCP 时会注入实际端口）
SUSHIRO_MCP_DESKTOP_PORT=39871
