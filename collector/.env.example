# 复制为 .env（已在 .gitignore）。systemd 用 EnvironmentFile=.env 加载。
# 环境变量优先级高于 config.json。

# 寿司郎公开接口 token（小程序请求头里的 Authorization Bearer）
SUSHIRO_COLLECTOR_SUSHIRO_TOKEN=

# Turso 新库（可读写，采集器写入用）
SUSHIRO_COLLECTOR_TURSO_URL=
SUSHIRO_COLLECTOR_TURSO_AUTH_TOKEN=

# 旧 Turso 库（只读，仅 migrate-old 导入压力历史用）
SUSHIRO_COLLECTOR_OLD_TURSO_URL=
SUSHIRO_COLLECTOR_OLD_TURSO_AUTH_TOKEN=
